# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The public URL where this app is hosted (used for Twilio webhook signature verification).
APP_URL="MY_APP_URL"

# Optional JWT configs
JWT_SECRET="super-secret-auth-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Encryption key used to encrypt and decrypt sensitive patient PII at rest (DPDP compliance)
ENCRYPTION_KEY="d6F3E0a51D1a457492a348901a1d1d12"

# Optional Twilio Integration (Simulated fallback by default if not set)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional Meta WhatsApp Integration
META_WEBHOOK_VERIFY_TOKEN=
META_ACCESS_TOKEN=

# Optional OpenAI fallback
OPENAI_API_KEY=

